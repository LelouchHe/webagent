{
  "name": "@lelouchhe/webagent",
  "version": "0.3.0",
  "description": "A terminal-style web UI for ACP-compatible agents",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LelouchHe/webagent.git"
  },
  "homepage": "https://github.com/LelouchHe/webagent#readme",
  "keywords": [
    "acp",
    "agent",
    "web-ui",
    "copilot",
    "chat",
    "sse"
  ],
  "engines": {
    "node": ">=22.6.0"
  },
  "bin": {
    "webagent": "bin/webagent.mjs"
  },
  "files": [
    "bin/",
    "lib/",
    "dist/",
    "config.toml"
  ],
  "scripts": {
    "compile": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run compile && npm run build",
    "build": "node scripts/build.js",
    "start": "node --experimental-strip-types src/server.ts --config config.toml",
    "test": "npm run compile && node --experimental-strip-types --test test/*.test.ts",
    "test:e2e": "playwright test",
    "dev": "node scripts/build.js --watch & node --experimental-strip-types --watch src/server.ts --config config.dev.toml",
    "dev:start": "node scripts/build.js --dev && node --experimental-strip-types src/server.ts --config config.dev.toml &",
    "dev:stop": "lsof -ti:6801 | xargs kill 2>/dev/null || true",
    "screenshots": "playwright test --config scripts/screenshots.config.ts",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@types/web-push": "^3.6.4",
    "better-sqlite3": "^12.6.2",
    "smol-toml": "^1.6.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "esbuild": "^0.27.3",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  }
}
