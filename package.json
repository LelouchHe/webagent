{
  "name": "webagent",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "test:e2e": "playwright test",
    "dev": "node --experimental-strip-types --watch src/server.ts --config config.dev.toml",
    "dev:start": "node --experimental-strip-types src/server.ts --config config.dev.toml &",
    "dev:stop": "lsof -ti:6801 | xargs kill 2>/dev/null || true",
    "svc:restart": "launchctl kickstart -k gui/501/com.lelouch.webagent",
    "svc:stop": "launchctl bootout gui/501/com.lelouch.webagent",
    "svc:status": "launchctl print gui/501/com.lelouch.webagent"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "better-sqlite3": "^12.6.2",
    "smol-toml": "^1.6.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1",
    "happy-dom": "^20.8.3",
    "playwright": "^1.58.2"
  }
}
